## Authentication & Session Management

### Recommended: NextAuth.js Configuration

```typescript
// pages/api/auth/[...nextauth].ts
import NextAuth from 'next-auth'
import CredentialsProvider from 'next-auth/providers/credentials'
import { z } from 'zod'

export default NextAuth({
  providers: [
    CredentialsProvider({
      name: 'credentials',
      credentials: {
        email: { label: 'Email', type: 'email' },
        password: { label: 'Password', type: 'password' }
      },
      async authorize(credentials) {
        const schema = z.object({
          email: z.string().email(),
          password: z.string().min(8)
        })
        
        const result = schema.safeParse(credentials)
        if (!result.success) throw new Error('Invalid credentials')

        const user = await verifyUser(result.data)
        if (!user) throw new Error('Invalid credentials')

        return { id: user.id, email: user.email, role: user.role }
      }
    })
  ],
  session: {
    strategy: 'jwt',
    maxAge: 30 * 24 * 60 * 60, // 30 days
    updateAge: 24 * 60 * 60
  },
  cookies: {
    sessionToken: {
      name: `__Secure-authjs.session-token`,
      options: {
        httpOnly: true,
        sameSite: 'lax',
        path: '/',
        secure: true // HTTPS only
      }
    }
  }
})
```

### Refresh Token Rotation

```typescript
export async function POST(req: Request) {
  const { refreshToken } = await req.json()
  const decoded = await verifyRefreshToken(refreshToken)
  if (!decoded) return new Response('Invalid token', { status: 401 })

  const newAccessToken = generateAccessToken(decoded.user)
  const newRefreshToken = generateRefreshToken(decoded.user)
  await invalidateRefreshToken(refreshToken) // Rotation

  return Response.json({ accessToken: newAccessToken, refreshToken: newRefreshToken })
}
```

### Password Requirements

```typescript
const PasswordSchema = z
  .string()
  .min(12, 'Password must be at least 12 characters')
  .regex(/[A-Z]/, 'Must contain uppercase letter')
  .regex(/[a-z]/, 'Must contain lowercase letter')
  .regex(/[0-9]/, 'Must contain number')
  .regex(/[^A-Za-z0-9]/, 'Must contain special character')

// Hash securely
import { hash, verify } from 'bcryptjs'
const hashedPassword = await hash(password, 12)
const isValid = await verify(password, hashedPassword)
```

