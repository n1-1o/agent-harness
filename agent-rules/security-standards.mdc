## Authentication & Session Management

### NextAuth.js

```typescript
import NextAuth from 'next-auth'
import CredentialsProvider from 'next-auth/providers/credentials'

export default NextAuth({
  providers: [
    CredentialsProvider({
      name: 'credentials',
      credentials: { email: { label: 'Email', type: 'email' }, password: { label: 'Password', type: 'password' } },
      async authorize(credentials) {
        // Verify and return { id, email, role } or throw
      }
    })
  ],
  session: { strategy: 'jwt', maxAge: 30 * 24 * 60 * 60 },
  cookies: {
    sessionToken: { name: `__Secure-authjs.session-token`, options: { httpOnly: true, sameSite: 'lax', path: '/', secure: true } }
  }
})
```

### Passwords

```typescript
const PasswordSchema = z.string().min(12).regex(/[A-Z]/).regex(/[a-z]/).regex(/[0-9]/).regex(/[^A-Za-z0-9]/)

import { hash } from 'bcryptjs'
const hashedPassword = await hash(password, 12)
