{
  "mcpServers": {
    "figma": {
      "command": "npx",
      "args": ["@figma/mcp"],
      "env": {
        "FIGMA_API_KEY": "your-figma-api-key"
      }
    },
    "vercel": {
      "command": "npx",
      "args": ["@vercel/mcp"],
      "env": {
        "VERCEL_TOKEN": "your-vercel-token"
      }
    },
    "gitlab": {
      "command": "npx",
      "args": ["@gitlab/mcp"],
      "env": {
        "GITLAB_TOKEN": "your-gitlab-token",
        "GITLAB_URL": "https://gitlab.com"
      }
    },
    "browser-tools": {
      "command": "npx",
      "args": ["browser-tools-mcp"]
    }
  }
}